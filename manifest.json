{
  "manifest_version": 3,
  "name": "스마트스토어 리뷰 답글 도우미",
  "version": "0.4.3",
  "description": "리뷰 가져오기·AI 생성·일괄 등록·톤 프리셋",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://sell.smartstore.naver.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "리뷰 답글 도우미",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://sell.smartstore.naver.com/*"],
      "js": ["config.js", "content.js", "content-import.js", "content-submit.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js"],
      "matches": ["https://sell.smartstore.naver.com/*"]
    }
  ]
}
