{
  "manifest_version": 3,
  "name": "스마트스토어 리뷰 답글 도우미",
  "version": "0.2.6",
  "description": "리뷰 엑셀/판매자센터 가져오기 → 선택·생성·검토 → 답글 자동 채우기",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://sell.smartstore.naver.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "리뷰 답글 도우미"
  },
  "content_scripts": [
    {
      "matches": ["https://sell.smartstore.naver.com/*"],
      "js": ["config.js", "content.js", "content-import.js"],
      "run_at": "document_idle"
    }
  ]
}
