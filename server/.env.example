# server/.env 로 복사 후 값 입력
GEMINI_API_KEY=AIzaYOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash
PORT=8787
APP_BASE_URL=http://127.0.0.1:8787

# 로컬 개발용 (확장 config.js API_DEV_SECRET 과 동일하게)
# 설정 시 로그인 없이 AI 호출 가능 (한도·구독 없음)
# DEV_API_SECRET=dev-change-me

# 계정·구독 (Phase 2)
# ALLOW_REGISTRATION=true
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=change-me-8chars
# ADMIN_SECRET=admin-change-me
# SESSION_DAYS=30

# 결제·구독 (Phase 3)
# BILLING_MOCK=true
# REQUIRE_SUBSCRIPTION=false
# SUBSCRIPTION_DAYS=30
# TOSS_CLIENT_KEY=test_ck_...
# TOSS_SECRET_KEY=test_sk_...
